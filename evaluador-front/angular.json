{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "homeprop-front": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/evaluador-front",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              },
              {
                "glob": "**/*",
                "input": "src/app-assets/fonts",
                "output": "assets/fonts"
              },
              {
                "glob": "**/*",
                "input": "src/app-assets/images",
                "output": "assets/images"
              },
              {
                "glob": "**/*",
                "input": "src/app-assets",
                "output": "assets"
              },
              "src/favicon.ico",
              "src/assets"
            ],
           "styles": [
              "src/app-assets/vendors/css/vendors.min.css",
              "src/app-assets/css/bootstrap.css",
              "src/app-assets/css/bootstrap-extended.css",
              "src/app-assets/css/colors.css",
              "src/app-assets/css/components.css",
              "src/app-assets/css/themes/dark-layout.css",
              "src/app-assets/css/themes/semi-dark-layout.css",
              "src/app-assets/css/core/menu/menu-types/vertical-menu.css",              
              "src/styles.css",
              "node_modules/@fortawesome/fontawesome-free/css/all.min.css"
            ],
            "scripts": [
              "node_modules/jquery/dist/jquery.min.js",
              "src/app-assets/vendors/js/vendors.min.js",
              "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js",
              "src/app-assets/js/core/app-menu.js",
              "src/app-assets/js/core/app.js"
            ]

          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5mb",
                  "maximumError": "5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "homeprop-front:build:production"
            },
            "development": {
              "buildTarget": "homeprop-front:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
